# ==============================================================================
# AI INTELLIGENCE ZONE — Control Arena
# Environment Configuration Template
# ==============================================================================
# Copy this to .env and fill in your values
# NEVER commit .env to version control
# ==============================================================================

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── Security (generate with: openssl rand -hex 32) ───────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string
JWT_SECRET_KEY=change-me-to-another-random-64-char-string
JWT_EXPIRY_HOURS=8
SESSION_LIFETIME_MINUTES=120

# ── Admin Credentials ────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ControlArena2026!
ADMIN_REGISTRATION_CODE=ARENA-ADMIN-2026

# ── Database (PostgreSQL for production) ────────────────────────────────────
# PostgreSQL connection string (recommended for production and events):
DATABASE_URL=postgresql://arena:arena_local_pass@localhost:5432/control_arena
# For local development with SQLite (not recommended for events):
# DATABASE_URL=sqlite:./data/control_arena.db

# ── Static CDN (Vercel) ──────────────────────────────────────────────────────
# Set this AFTER deploying frontend/ to Vercel. Leave empty to serve static
# files directly from Railway (no CDN).
STATIC_CDN_URL=https://your-app.vercel.app

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins, or * for open access (event/hackathon use)
CORS_ORIGINS=*
SESSION_LIFETIME_MINUTES=120
JWT_EXPIRY_HOURS=8
ADMIN_REGISTRATION_CODE=ARENA-ADMIN-2026

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=200
SUBMIT_RATE_LIMIT_PER_MINUTE=10

# ── Competition Settings ─────────────────────────────────────────────────────
COMPETITION_NAME=AI Intelligence Zone — Control Arena
MAX_TEAMS=50
MAX_TEAM_MEMBERS=4
SUBMISSION_COOLDOWN_SECONDS=10
MAX_RETRIES_PER_MISSION=20
COMPETITION_START=2026-03-15T09:00:00Z
COMPETITION_END=2026-03-15T18:00:00Z

# ── Scoring Weights (must sum to 1.0) ────────────────────────────────────────
WEIGHT_ACCURACY=0.50
WEIGHT_SPEED=0.20
WEIGHT_VALIDATION=0.30

# ── Scoring Bonuses ───────────────────────────────────────────────────────────
FIRST_BLOOD_BONUS=50
PERFECT_PARSE_BONUS=25
SPEED_DEMON_BONUS=30
CONSISTENCY_BONUS=20
EFFICIENT_PROMPT_BONUS=15
