# ==============================================================================
# AI INTELLIGENCE ZONE — Control Arena
# .gitignore
# ==============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/

# Virtual environment
venv/
.venv/
env/
.env.*  # Ignore all .env files (e.g., .env.local, .env.dev)
.env.example  # But keep the example .env file
# Environment & secrets
.env

# SQLite database (dev)
instance/
*.db
*.sqlite

# Logs
logs/
*.log

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Node
backend/node_modules/

# Docker volumes
postgres-data/
redis-data/

# Nginx (removed — not needed)
nginx/

# Coverage
htmlcov/
.coverage
.pytest_cache/

# Celery
celerybeat-schedule*
node_modules
