<%# views/admin/missions.ejs %>

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="page-title">🚩 Missions</h1>
        <p class="page-subtitle">Manage competition missions and visibility.</p>
    </div>
    <div class="toolbar">
        <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#createMissionModal">
            <i class="bi bi-plus-lg"></i> New Mission
        </button>
    </div>
</div>

<div class="row g-3">
<% missions.forEach(function(m) { %>
<div class="col-lg-6">
    <div class="arena-panel p-3 h-100">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
                <span class="badge bg-primary font-monospace me-2"><%= m.missionCode %></span>
                <strong><%= m.title %></strong>
            </div>
            <div class="d-flex gap-2 align-items-center">
                <% if (m.isVisible) { %>
                    <span class="badge bg-success">Visible</span>
                <% } else { %>
                    <span class="badge bg-secondary">Hidden</span>
                <% } %>
                <form method="POST" action="/admin/missions/<%= m.id %>/toggle" class="d-inline">
                    <button class="btn btn-xs <%= m.isVisible ? 'btn-outline-warning' : 'btn-outline-success' %>">
                        <i class="bi bi-<%= m.isVisible ? 'eye-slash' : 'eye' %>"></i>
                        <%= m.isVisible ? 'Hide' : 'Show' %>
                    </button>
                </form>
            </div>
        </div>
        <p class="text-muted small mb-2"><%= (m.description || '').substring(0, 180) %><%= (m.description || '').length > 180 ? '…' : '' %></p>
        <div class="d-flex gap-3 flex-wrap" style="font-size:.78rem;">
            <span>
                <span class="text-muted">Difficulty:</span>
                <% if (m.difficulty === 'hard' || m.difficulty === 'expert') { %>
                    <span class="text-danger fw-semibold"><%= m.difficulty %></span>
                <% } else if (m.difficulty === 'medium') { %>
                    <span class="text-warning fw-semibold"><%= m.difficulty %></span>
                <% } else { %>
                    <span class="text-success fw-semibold"><%= m.difficulty %></span>
                <% } %>
            </span>
            <span><span class="text-muted">Points:</span> <span class="text-info fw-semibold"><%= m.maxPoints %></span></span>
            <span><span class="text-muted">Retries:</span> <span><%= m.maxRetries %></span></span>
            <span><span class="text-muted">Time:</span> <span><%= m.timeLimitSeconds %>s</span></span>
            <span><span class="text-muted">Order:</span> <span>#<%= m.orderIndex %></span></span>
            <% if (m.category) { %>
            <span><span class="badge bg-info text-dark"><%= m.category %></span></span>
            <% } %>
        </div>
    </div>
</div>
<% }) %>
<% if (missions.length === 0) { %>
<div class="col-12"><p class="text-muted text-center py-5">No missions yet. Create one to get started.</p></div>
<% } %>
</div>

<!-- Create Mission Modal -->
<div class="modal fade" id="createMissionModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content bg-dark border-secondary">
            <div class="modal-header border-secondary">
                <h5 class="modal-title">Create New Mission</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="POST" action="/admin/missions/create">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Mission Code</label>
                            <input name="mission_code" class="form-control bg-dark text-white border-secondary" placeholder="M06" required>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">Title</label>
                            <input name="title" class="form-control bg-dark text-white border-secondary" placeholder="Mission title" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <textarea name="description" rows="3" class="form-control bg-dark text-white border-secondary"></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Difficulty</label>
                            <select name="difficulty" class="form-select bg-dark text-white border-secondary">
                                <option value="easy">Easy</option>
                                <option value="medium" selected>Medium</option>
                                <option value="hard">Hard</option>
                                <option value="expert">Expert</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Max Points</label>
                            <input name="max_points" type="number" step="0.01" class="form-control bg-dark text-white border-secondary" value="100">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Time Limit (seconds)</label>
                            <input name="time_limit" type="number" class="form-control bg-dark text-white border-secondary" value="600">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Max Retries</label>
                            <input name="max_retries" type="number" class="form-control bg-dark text-white border-secondary" value="20">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Category</label>
                            <input name="category" class="form-control bg-dark text-white border-secondary" placeholder="e.g. NLP, Vision">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Order Index</label>
                            <input name="order_index" type="number" class="form-control bg-dark text-white border-secondary" value="<%= missions.length + 1 %>">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Expected Schema (JSON)</label>
                            <textarea name="expected_schema" rows="3" class="form-control bg-dark text-white border-secondary font-monospace" placeholder='{"answer": "string"}'></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Sample Response</label>
                            <textarea name="sample_response" rows="3" class="form-control bg-dark text-white border-secondary font-monospace"></textarea>
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input name="is_visible" value="1" type="checkbox" class="form-check-input" id="isVisible" checked>
                                <label class="form-check-label" for="isVisible">Visible to teams immediately</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Mission</button>
                </div>
            </form>
        </div>
    </div>
</div>
