<!-- views/errors/500.ejs -->
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <title>Server Error | AI Intelligence Zone</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>body{background:#020617;min-height:100vh;display:flex;align-items:center;justify-content:center;font-family:'Inter',sans-serif;}</style>
</head>
<body>
<div class="text-center">
    <h1 style="font-size:5rem;color:#ef4444;">500</h1>
    <h2 class="text-light mb-3">Internal Server Error</h2>
    <p class="text-muted mb-4">Something went wrong. Please try again.</p>
    <% if (error && error.message) { %>
        <pre class="text-danger" style="font-size:.75rem;text-align:left;max-width:600px;margin:0 auto 1rem;"><%= error.message %></pre>
    <% } %>
    <a href="/" class="btn btn-outline-danger">← Back to Home</a>
</div>
</body>
</html>
