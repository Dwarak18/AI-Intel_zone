<!-- views/team/mission_console.ejs -->
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mission Console | AI Intelligence Zone</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/static/css/arena.css">
    <style>
        .console-grid { display:grid; grid-template-columns:380px 1fr; gap:1rem; align-items:start; }
        @media(max-width:900px){ .console-grid{grid-template-columns:1fr;} }
        .brief-panel,.editor-panel { background:var(--surface,#0f172a); border:1px solid var(--border,#1e293b); border-radius:8px; overflow:hidden; }
        .brief-header { background:rgba(99,102,241,.12); border-bottom:1px solid var(--border,#1e293b); padding:.75rem 1rem; }
        .brief-body { padding:1rem; }
        .editor-header { background:rgba(99,102,241,.08); border-bottom:1px solid var(--border,#1e293b); padding:.6rem 1rem; display:flex; justify-content:space-between; align-items:center; }
        .editor-body { padding:1rem; }
        .json-status { display:inline-flex; align-items:center; gap:.35rem; font-size:.78rem; padding:.25rem .6rem; border-radius:20px; font-weight:600; transition:all .2s; }
        .json-status.valid { background:rgba(16,185,129,.15); color:#10b981; }
        .json-status.invalid { background:rgba(239,68,68,.15); color:#ef4444; }
        .json-status.empty { background:rgba(99,102,241,.10); color:#6366f1; }
        .feedback-box { border-radius:6px; border:1px solid var(--border,#1e293b); padding:.85rem 1rem; font-size:.82rem; transition:border-color .3s,background .3s; }
        .attempt-badge { font-size:.72rem; padding:.2rem .55rem; border-radius:12px; background:rgba(99,102,241,.15); color:#818cf8; font-weight:600; }
        .attempt-badge.warn { background:rgba(249,115,22,.15); color:#fb923c; }
        .attempt-badge.danger { background:rgba(239,68,68,.15); color:#f87171; }
        .input-text-box { background:rgba(16,185,129,.07); border:1px solid rgba(16,185,129,.3); border-radius:6px; padding:.75rem; font-size:.82rem; line-height:1.5; cursor:pointer; user-select:all; }
    </style>
</head>
<body>
<div class="d-flex" style="min-height:100vh;">
    <!-- Sidebar -->
    <nav style="width:200px;min-width:200px;background:#0a0f1e;border-right:1px solid #1e293b;padding:1.5rem 1rem;display:flex;flex-direction:column;gap:.5rem;">
        <div style="font-family:'JetBrains Mono',monospace;color:#6366f1;font-size:.85rem;font-weight:700;margin-bottom:1.5rem;">⚡ TEAM PORTAL</div>
        <a href="/team/console" class="btn btn-sm btn-outline-primary text-start"><i class="bi bi-terminal-fill me-2"></i>Mission Console</a>
        <div style="flex:1;"></div>
        <a href="/auth/logout" class="btn btn-sm btn-outline-danger text-start"><i class="bi bi-box-arrow-right me-2"></i>Logout</a>
    </nav>

    <!-- Main -->
    <div style="flex:1;padding:1.5rem;overflow:auto;">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <h1 class="page-title" style="font-size:1.4rem;font-weight:700;margin-bottom:.25rem;">🎯 Mission Console</h1>
                <p class="text-muted" style="font-size:.85rem;margin:0;">Select a mission, read the brief, and submit your AI's response.</p>
            </div>
            <div class="d-flex align-items-center gap-2">
                <div class="badge bg-danger d-none" id="cooldownTimer">Cooldown: 00s</div>
                <select id="missionSelect" class="form-select form-select-sm" style="width:240px;">
                    <option value="">⏳ Loading missions…</option>
                </select>
            </div>
        </div>

        <!-- Flash messages -->
        <% if (typeof flash !== 'undefined' && flash) { %>
            <% if (flash.error && flash.error.length) flash.error.forEach(m => { %>
            <div class="alert alert-danger alert-dismissible fade show py-2" style="font-size:.82rem;">
                <%= m %><button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
            </div>
            <% }) %>
        <% } %>

        <div class="console-grid mb-4">
            <!-- Mission Brief -->
            <aside class="brief-panel">
                <div class="brief-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-semibold small text-primary" id="missionCode">—</span>
                        <span class="badge bg-secondary d-none ms-auto me-2" id="difficultyBadge"></span>
                        <span id="attemptsBadge" class="attempt-badge">0 / 0 attempts</span>
                    </div>
                    <h6 class="mb-0 mt-1" id="missionTitle">Select a Mission</h6>
                </div>
                <div class="brief-body" id="briefBody">
                    <p class="text-muted small mt-2">↑ Choose a mission from the dropdown above to see the brief.</p>
                </div>
            </aside>

            <!-- Editor -->
            <div>
                <div class="editor-panel mb-3">
                    <div class="editor-header">
                        <span class="small fw-semibold">Your Prompt</span>
                        <small class="text-muted">Prompt length: <span id="promptLength">0</span> chars</small>
                    </div>
                    <div class="editor-body pb-2">
                        <textarea class="form-control mb-0" id="promptEditor" rows="3"
                            placeholder="Write the prompt you sent to the AI…"></textarea>
                    </div>
                </div>

                <div class="editor-panel mb-3">
                    <div class="editor-header">
                        <span class="small fw-semibold">AI Response</span>
                        <span class="json-status empty" id="jsonStatus">✦ Paste JSON here</span>
                    </div>
                    <div class="editor-body pb-2">
                        <textarea class="form-control font-monospace" id="aiResponseEditor" rows="10"
                            placeholder='{ "key": "value" }' spellcheck="false"></textarea>
                    </div>
                    <div class="px-3 pb-3 d-flex justify-content-end gap-2">
                        <button class="btn btn-outline-secondary btn-sm" id="formatJsonBtn" type="button">⚡ Format</button>
                        <button class="btn btn-outline-info btn-sm" id="sandboxBtn" type="button">🧪 Sandbox</button>
                        <button class="btn btn-primary btn-sm" id="submitPromptBtn" type="button" disabled>🚀 Submit</button>
                    </div>
                </div>

                <div class="feedback-box" id="feedbackBox" style="background:rgba(99,102,241,.04);border:1px solid #1e293b;">
                    <div id="feedbackContent" class="text-muted small">Awaiting submission…</div>
                    <div class="d-flex align-items-center gap-3 mt-2 d-none" id="scoreLine">
                        <span class="badge bg-success">Score</span>
                        <strong id="scoreValue" class="text-success">0</strong>
                        <span class="text-muted small ms-2">Confidence:</span>
                        <span id="confidenceValue" class="small fw-semibold">0.00</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Submission History -->
        <section class="arena-table" style="background:#0f172a;border:1px solid #1e293b;border-radius:8px;overflow:hidden;">
            <div class="p-3 border-bottom border-secondary d-flex justify-content-between align-items-center" style="background:rgba(99,102,241,.06);">
                <span class="fw-semibold small">📋 Submission History</span>
                <span class="text-muted small" id="historyMissionLabel">— no mission selected —</span>
            </div>
            <table class="table table-dark table-hover mb-0">
                <thead>
                    <tr>
                        <th style="width:55px">#</th>
                        <th style="width:110px">Time</th>
                        <th style="width:80px">Status</th>
                        <th style="width:70px">Score</th>
                        <th style="width:90px">Confidence</th>
                        <th>Feedback</th>
                    </tr>
                </thead>
                <tbody id="submissionHistoryBody">
                    <tr><td colspan="6" class="text-center text-muted py-4">Select a mission to see history.</td></tr>
                </tbody>
            </table>
        </section>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/static/socket.io.min.js" onerror="this.onerror=null;"></script>
<script>if(typeof io==='undefined'){var s=document.createElement('script');s.src='https://cdn.socket.io/4.7.5/socket.io.min.js';document.head.appendChild(s);}</script>
<script src="/static/js/team_console.js"></script>
</body>
</html>
