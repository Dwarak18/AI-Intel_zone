{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "ai-zone-static",

  "headers": [
    {
      "source": "/static/:path*",
      "headers": [
        { "key": "Cache-Control",              "value": "public, max-age=31536000, immutable" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],

  "rewrites": [
    { "source": "/(.*)", "destination": "/$1" }
  ],

  "cleanUrls": false,
  "trailingSlash": false
}
