<%# views/admin/audit.ejs %>

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="page-title">📋 Audit Trail</h1>
        <p class="page-subtitle">All admin and system actions with full context.</p>
    </div>
    <div class="toolbar">
        <form method="POST" action="/admin/audit/export" class="d-inline">
            <button class="btn btn-sm btn-outline-info"><i class="bi bi-download"></i> Export JSON</button>
        </form>
    </div>
</div>

<form method="GET" action="/admin/audit" class="d-flex gap-2 mb-3 flex-wrap">
    <select name="action" class="form-select form-select-sm bg-dark text-white border-secondary" style="max-width:200px;" onchange="this.form.submit()">
        <option value="">All Actions</option>
        <% actionList.forEach(function(a) { %>
        <option value="<%= a %>" <%= filters.actionFilter === a ? 'selected' : '' %>><%= a %></option>
        <% }) %>
    </select>
    <select name="severity" class="form-select form-select-sm bg-dark text-white border-secondary" style="max-width:150px;" onchange="this.form.submit()">
        <option value="">All Severities</option>
        <option value="info" <%= filters.severityFilter === 'info' ? 'selected' : '' %>>Info</option>
        <option value="warning" <%= filters.severityFilter === 'warning' ? 'selected' : '' %>>Warning</option>
        <option value="critical" <%= filters.severityFilter === 'critical' ? 'selected' : '' %>>Critical</option>
    </select>
    <a href="/admin/audit" class="btn btn-sm btn-outline-secondary">Clear</a>
</form>

<div class="arena-table">
    <table class="table table-dark table-hover table-sm mb-0">
        <thead>
            <tr><th>Time</th><th>Action</th><th>Severity</th><th>Message</th><th>User ID</th><th>IP</th></tr>
        </thead>
        <tbody>
        <% logs.forEach(function(log) { %>
        <tr>
            <td class="text-muted small text-nowrap"><%= log.createdAt ? new Date(log.createdAt).toLocaleString() : '' %></td>
            <td><span class="badge bg-secondary font-monospace"><%= log.action %></span></td>
            <td>
                <% if (log.severity === 'critical') { %>
                    <span class="badge bg-danger">CRITICAL</span>
                <% } else if (log.severity === 'warning') { %>
                    <span class="badge bg-warning text-dark">WARNING</span>
                <% } else { %>
                    <span class="badge bg-info text-dark">INFO</span>
                <% } %>
            </td>
            <td class="small"><%= (log.message || '').substring(0, 120) %><%= (log.message || '').length > 120 ? '…' : '' %></td>
            <td class="text-muted small"><%= log.userId || '—' %></td>
            <td class="text-muted small font-monospace"><%= log.ipAddress || '—' %></td>
        </tr>
        <% }) %>
        <% if (logs.length === 0) { %>
        <tr><td colspan="6" class="text-center text-muted py-4">No audit logs found.</td></tr>
        <% } %>
        </tbody>
    </table>
</div>

<% if (pagination.pages > 1) { %>
<nav class="mt-3">
    <ul class="pagination pagination-sm justify-content-center">
        <% for (var p = 1; p <= pagination.pages; p++) { %>
        <li class="page-item <%= p === pagination.page ? 'active' : '' %>">
            <a class="page-link" href="?page=<%= p %>&action=<%= filters.actionFilter || '' %>&severity=<%= filters.severityFilter || '' %>"><%= p %></a>
        </li>
        <% } %>
    </ul>
</nav>
<% } %>
