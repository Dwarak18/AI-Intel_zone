<%# views/admin/dashboard.ejs %>

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="page-title">⚡ Mission Control</h1>
        <p class="page-subtitle">Live operations, health telemetry, and real-time activity.</p>
    </div>
    <div class="toolbar">
        <a href="/admin/activity" class="btn btn-sm btn-outline-info"><i class="bi bi-activity"></i> Activity Monitor</a>
        <button class="btn btn-sm btn-outline-secondary" onclick="refreshStats()"><i class="bi bi-arrow-repeat"></i> Refresh</button>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:rgba(109,125,255,.2);color:#8ea2ff;"><i class="bi bi-people-fill"></i></div>
            <div class="stat-value" id="stat-total-teams"><%= totalTeams %></div>
            <div class="stat-label">Teams Registered</div>
            <div class="kpi-mini mt-2"><%= activeTeams %> active &middot; <%= lockedTeams %> locked &middot; <%= disqualifiedTeams %> dq</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:rgba(34,197,94,.18);color:#86efac;"><i class="bi bi-send-check-fill"></i></div>
            <div class="stat-value" id="stat-total-subs"><%= totalSubmissions %></div>
            <div class="stat-label">Total Submissions</div>
            <div class="kpi-mini mt-2"><%= validSubmissions %> valid &middot; <%= invalidSubmissions %> invalid &middot; <%= errorSubmissions %> error</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:rgba(6,182,212,.18);color:#67e8f9;"><i class="bi bi-check2-circle"></i></div>
            <div class="stat-value" id="stat-validation-rate"><%= validationRate %>%</div>
            <div class="stat-label">Validation Success</div>
            <div class="score-bar mt-2">
                <div class="score-bar-fill" style="width:<%= validationRate %>%;background:linear-gradient(90deg,#ef4444,#f59e0b,#22c55e)"></div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:rgba(239,68,68,.2);color:#fda4af;"><i class="bi bi-shield-exclamation"></i></div>
            <div class="stat-value" id="stat-security"><%= openSecurityEvents %></div>
            <div class="stat-label">Open Security Events</div>
            <div class="kpi-mini mt-2"><%= flaggedSubmissions %> flagged submissions</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="stat-card"><div class="stat-label">Submissions (1h)</div><div class="stat-value" id="stat-recent"><%= recentSubmissions %></div></div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card"><div class="stat-label">Active Teams (15m)</div><div class="stat-value" id="activeTeamsCounter">—</div></div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card"><div class="stat-label">Hallucination Rate</div><div class="stat-value" id="hallucinationRate">—</div></div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card"><div class="stat-label">Server Queue Depth</div><div class="stat-value" id="serverQueueDepth">—</div></div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-xl-8">
        <section class="arena-panel p-3 h-100">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="mb-0">Submission Activity Trend (24h)</h6>
                <small class="text-muted">Auto-updates</small>
            </div>
            <div style="height:280px;"><canvas id="submissionTrendChart"></canvas></div>
        </section>
    </div>
    <div class="col-xl-4">
        <section class="arena-panel p-3 h-100">
            <h6 class="mb-2">Validation Status Chart</h6>
            <div style="height:280px;"><canvas id="validationStatusChart"></canvas></div>
        </section>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-7">
        <div class="arena-table">
            <div class="d-flex justify-content-between align-items-center px-3 py-2" style="border-bottom:1px solid var(--arena-border)">
                <h6 class="mb-0">🏆 Top Teams</h6>
                <a href="/admin/leaderboard" class="small text-decoration-none">Open leaderboard →</a>
            </div>
            <table class="table table-dark table-hover mb-0">
                <thead>
                    <tr><th>Rank</th><th>Team</th><th>Score</th><th>Missions</th><th>Valid %</th><th>Health</th></tr>
                </thead>
                <tbody>
                <% topTeams.forEach(function(t) { %>
                <tr>
                    <td>
                        <% if (t.currentRank === 1) { %>
                            <span class="badge bg-warning text-dark">🥇</span>
                        <% } else if (t.currentRank === 2) { %>
                            <span class="badge bg-secondary">🥈</span>
                        <% } else if (t.currentRank === 3) { %>
                            <span class="badge bg-danger">🥉</span>
                        <% } else { %>
                            <span class="text-muted">#<%= t.currentRank || '-' %></span>
                        <% } %>
                    </td>
                    <td><strong><%= t.teamCode %></strong> <span class="text-muted small"><%= t.name %></span></td>
                    <td style="font-family:'JetBrains Mono',monospace;"><%= (t.totalScore || 0).toFixed(1) %></td>
                    <td><%= t.missionsCompleted || 0 %></td>
                    <td><%= (t.validationRate || 0).toFixed(0) %>%</td>
                    <td>
                        <div class="score-bar" style="width:68px;">
                            <div class="score-bar-fill" style="width:<%= t.healthScore || 0 %>%"></div>
                        </div>
                    </td>
                </tr>
                <% }) %>
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-lg-5">
        <section class="arena-panel p-3 h-100">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="mb-0">📡 Real-Time Activity</h6>
                <small><a class="text-decoration-none" href="/admin/activity">full view</a></small>
            </div>
            <div id="live-feed" style="max-height:380px;overflow-y:auto;">
                <% recentSubs.forEach(function(sub) { %>
                <article class="d-flex justify-content-between align-items-center p-2 mb-1 rounded"
                    style="background:rgba(255,255,255,.04);border-left:3px solid <%= (sub.isFlagged || sub.injectionDetected) ? '#ef4444' : (sub.validationStatus === 'valid' ? '#22c55e' : '#f59e0b') %>;">
                    <div>
                        <div class="fw-semibold small"><%= sub.team ? sub.team.teamCode : 'N/A' %> &middot; <%= sub.mission ? sub.mission.title : 'Unknown' %></div>
                        <div class="text-muted" style="font-size:.7rem;"><%= sub.createdAt ? new Date(sub.createdAt).toTimeString().slice(0,8) : '' %> &middot; Attempt #<%= sub.attemptNumber %></div>
                    </div>
                    <div>
                        <% if (sub.isFlagged || sub.injectionDetected) { %>
                            <span class="badge bg-danger">Suspicious</span>
                        <% } else if (sub.validationStatus === 'valid') { %>
                            <span class="badge bg-success">VALID</span>
                        <% } else if (sub.validationStatus === 'invalid') { %>
                            <span class="badge bg-warning text-dark">INVALID</span>
                        <% } else { %>
                            <span class="badge bg-secondary">ERROR</span>
                        <% } %>
                    </div>
                </article>
                <% }) %>
            </div>
        </section>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script src="<%= staticUrl %>/static/js/dashboard.js"></script>
