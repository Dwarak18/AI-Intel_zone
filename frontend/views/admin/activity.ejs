<%# views/admin/activity.ejs %>

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="page-title">📡 Activity Monitor</h1>
        <p class="page-subtitle">Real-time submissions, rate analysis, and anomaly detection.</p>
    </div>
    <div class="toolbar">
        <button class="btn btn-sm btn-outline-secondary" onclick="location.reload()"><i class="bi bi-arrow-repeat"></i> Refresh</button>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-7">
        <section class="arena-panel p-3 h-100">
            <h6 class="mb-3">🔴 Live Submissions (Last 50)</h6>
            <div style="max-height:420px;overflow-y:auto;">
                <table class="table table-dark table-hover table-sm mb-0">
                    <thead><tr><th>Time</th><th>Team</th><th>Mission</th><th>Attempt</th><th>Status</th><th>Score</th><th>Flags</th></tr></thead>
                    <tbody>
                    <% recent.forEach(function(sub) { %>
                    <tr class="<%= sub.isFlagged || sub.injectionDetected ? 'table-danger' : '' %>">
                        <td class="text-muted small"><%= sub.createdAt ? new Date(sub.createdAt).toTimeString().slice(0,8) : '' %></td>
                        <td><span class="badge bg-secondary"><%= sub.team ? sub.team.teamCode : 'N/A' %></span></td>
                        <td class="small"><%= sub.mission ? sub.mission.title : '—' %></td>
                        <td class="text-center"><%= sub.attemptNumber %></td>
                        <td>
                            <% if (sub.validationStatus === 'valid') { %>
                                <span class="badge bg-success">VALID</span>
                            <% } else if (sub.validationStatus === 'invalid') { %>
                                <span class="badge bg-warning text-dark">INVALID</span>
                            <% } else { %>
                                <span class="badge bg-secondary">ERROR</span>
                            <% } %>
                        </td>
                        <td class="font-monospace small"><%= (sub.totalScore || 0).toFixed(1) %></td>
                        <td>
                            <% if (sub.isFlagged) { %><span class="badge bg-danger me-1" title="Flagged">F</span><% } %>
                            <% if (sub.injectionDetected) { %><span class="badge bg-danger" title="Injection">I</span><% } %>
                        </td>
                    </tr>
                    <% }) %>
                    </tbody>
                </table>
            </div>
        </section>
    </div>
    <div class="col-lg-5">
        <section class="arena-panel p-3 mb-3">
            <h6 class="mb-3">⚡ Submission Frequency (1h)</h6>
            <table class="table table-dark table-sm mb-0">
                <thead><tr><th>Team</th><th>Submissions</th></tr></thead>
                <tbody>
                <% frequency.forEach(function(row) { %>
                <tr>
                    <td><span class="badge bg-secondary"><%= row.team_code || row.teamCode || 'N/A' %></span> <small class="text-muted"><%= row.team_name || row.teamName || '' %></small></td>
                    <td><strong><%= row.count %></strong></td>
                </tr>
                <% }) %>
                <% if (frequency.length === 0) { %>
                <tr><td colspan="2" class="text-center text-muted">No submissions in the last hour.</td></tr>
                <% } %>
                </tbody>
            </table>
        </section>

        <section class="arena-panel p-3">
            <h6 class="mb-3">🚨 Flagged Submissions</h6>
            <div style="max-height:200px;overflow-y:auto;">
            <% flagged.forEach(function(sub) { %>
            <article class="d-flex justify-content-between align-items-center p-2 mb-1 rounded" style="background:rgba(239,68,68,.1);border-left:3px solid #ef4444;">
                <div>
                    <div class="fw-semibold small"><%= sub.team ? sub.team.teamCode : 'N/A' %></div>
                    <div class="text-muted" style="font-size:.7rem;"><%= sub.createdAt ? new Date(sub.createdAt).toLocaleString() : '' %></div>
                </div>
                <span class="badge bg-danger">Flagged</span>
            </article>
            <% }) %>
            <% if (flagged.length === 0) { %>
            <p class="text-muted small">No flagged submissions.</p>
            <% } %>
            </div>
        </section>
    </div>
</div>

<% if (hallucinationData && hallucinationData.length > 0) { %>
<section class="arena-panel p-3">
    <h6 class="mb-3">🧠 Hallucination Counts by Team</h6>
    <div class="row g-2">
    <% hallucinationData.forEach(function(team) { %>
    <div class="col-xl-3 col-md-4 col-6">
        <div class="p-2 rounded text-center" style="background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.2);">
            <div class="fw-bold text-danger font-monospace"><%= team.hallucinationCount %></div>
            <div class="small text-muted"><%= team.teamCode %></div>
        </div>
    </div>
    <% }) %>
    </div>
</section>
<% } %>
