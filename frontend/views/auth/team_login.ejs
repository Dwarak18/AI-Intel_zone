<!-- ========================================================================
     AI INTELLIGENCE ZONE — Team Login (views/auth/team_login.ejs)
     ======================================================================== -->
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Team Login | AI Intelligence Zone</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        body { background:#020617; min-height:100vh; display:flex; align-items:center; justify-content:center; font-family:'Inter',sans-serif; }
        .login-container { width:100%; max-width:440px; padding:2rem; }
        .login-card { background:#0f172a; border:1px solid #1e293b; border-radius:18px; padding:2.5rem; box-shadow:0 0 80px rgba(16,185,129,.12),0 20px 60px rgba(0,0,0,.5); }
        .login-brand { text-align:center; margin-bottom:2rem; }
        .login-brand .brand-icon { width:64px;height:64px;background:linear-gradient(135deg,#10b981,#059669);border-radius:16px;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.8rem;box-shadow:0 4px 20px rgba(16,185,129,.4); }
        .login-brand h1 { font-family:'JetBrains Mono',monospace; font-size:1rem; font-weight:700; color:#10b981; letter-spacing:2px; margin:0; }
        .login-brand p { color:#475569; font-size:.7rem; text-transform:uppercase; letter-spacing:3px; margin:.3rem 0 0; }
        .form-control { background:#1e293b; border:1px solid #334155; color:#e2e8f0; padding:.75rem 1rem; font-size:.9rem; border-radius:8px; }
        .form-control:focus { background:#1e293b; border-color:#10b981; color:#e2e8f0; box-shadow:0 0 0 3px rgba(16,185,129,.2); }
        .form-control::placeholder { color:#475569; }
        .form-label { font-size:.7rem; color:#64748b; text-transform:uppercase; letter-spacing:1px; margin-bottom:.4rem; }
        .btn-arena { background:linear-gradient(135deg,#10b981,#14b8a6); border:none; color:#fff; padding:.8rem; font-weight:600; border-radius:10px; width:100%; font-size:.95rem; transition:all .25s; }
        .btn-arena:hover { transform:translateY(-1px); box-shadow:0 6px 24px rgba(16,185,129,.4); color:#fff; }
        .glow-line { height:1px; background:linear-gradient(90deg,transparent,#10b981,transparent); margin:1.5rem 0; }
        .team-hint { background:#1e293b; border:1px solid #334155; border-radius:8px; padding:.6rem .9rem; font-size:.75rem; color:#64748b; margin-bottom:1.25rem; }
        .team-hint strong { color:#94a3b8; font-family:'JetBrains Mono',monospace; }
    </style>
</head>
<body>
<div class="login-container">
    <div class="login-card">
        <div class="login-brand">
            <div class="brand-icon">🛡️</div>
            <h1>AI INTEL ZONE</h1>
            <p>Team Access Portal</p>
        </div>
        <div class="glow-line"></div>

        <% if (locals.error && error.length) { error.forEach(function(m) { %>
        <div class="alert alert-danger py-2 px-3" style="font-size:.8rem;"><i class="bi bi-exclamation-triangle-fill me-1"></i><%= m %></div>
        <% }) } %>
        <% if (locals.success && success.length) { success.forEach(function(m) { %>
        <div class="alert alert-success py-2 px-3" style="font-size:.8rem;"><%= m %></div>
        <% }) } %>

        <div class="team-hint">
            <i class="bi bi-info-circle me-1"></i>
            Enter your team code (e.g. <strong>TECH-385276</strong>) and team password.
        </div>

        <form method="POST" action="/auth/team-session">
            <div class="mb-3">
                <label class="form-label"><i class="bi bi-people-fill me-1"></i>Team Code</label>
                <input type="text" name="team_code" class="form-control" placeholder="TECH-XXXXXX"
                       required autofocus autocomplete="off"
                       style="text-transform:uppercase;font-family:'JetBrains Mono',monospace;letter-spacing:1px;">
            </div>
            <div class="mb-4">
                <label class="form-label"><i class="bi bi-key-fill me-1"></i>Team Password</label>
                <input type="password" name="password" class="form-control" placeholder="Enter team password" required>
            </div>
            <button type="submit" class="btn btn-arena">
                <i class="bi bi-box-arrow-in-right me-2"></i>Enter Mission Console
            </button>
        </form>

        <div class="glow-line"></div>
        <p class="text-center mb-0" style="font-size:.75rem;color:#64748b;">
            Admin account? <a href="/auth/login" class="link-success">Go to admin login</a>
        </p>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Auto-uppercase team code
    const tc = document.querySelector('input[name="team_code"]');
    if (tc) tc.addEventListener('input', function() {
        const p = this.selectionStart;
        this.value = this.value.toUpperCase();
        this.setSelectionRange(p, p);
    });
</script>
</body>
</html>
